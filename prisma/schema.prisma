// Okara Mart — Dark Store Database Schema
// Single-city (Okara) grocery/dark-store platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ACCESS CONTROL ----------

enum Role {
  SUPER_ADMIN   // full access: users, settings, payouts
  MANAGER       // inventory, orders, discounts
  PACKER        // sees orders to pack, marks packed
  RIDER         // sees assigned deliveries only
  CUSTOMER
}

model User {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?  @unique
  passwordHash  String?
  role          Role     @default(CUSTOMER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  addresses     Address[]
  orders        Order[]        @relation("CustomerOrders")
  ridingOrders  Order[]        @relation("RiderOrders")
  reviews       Review[]
}

// OTP codes for customer phone signup/login. Short-lived, single-use.
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  purpose   String   // "SIGNUP" | "LOGIN"
  expiresAt DateTime
  consumedAt DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  label      String   // "Home", "Office"
  addressLine String
  area       String   // Okara neighborhood/sector, used for delivery zoning
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ---------- CATALOG ----------

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  imageUrl String?
  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  imageUrl      String?
  price         Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2) // for showing discounts
  unit          String   // "1 kg", "500 ml", "1 pc"
  sku           String   @unique
  stockQty      Int      @default(0)
  lowStockAlertAt Int    @default(5)
  isActive      Boolean  @default(true)
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems    OrderItem[]
  reviews       Review[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
}

// ---------- ORDERS ----------

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // human friendly e.g. OKM-10234
  customerId      String
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  addressId       String
  addressSnapshot String        // frozen copy of address text at order time
  riderId         String?
  rider           User?         @relation("RiderOrders", fields: [riderId], references: [id])

  status          OrderStatus   @default(PLACED)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)

  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2) @default(0)
  discount        Decimal       @db.Decimal(10, 2) @default(0)
  total           Decimal       @db.Decimal(10, 2)

  couponCode      String?
  deliverySlot    String?       // "ASAP" or a scheduled window
  otpCode         String?       // for COD delivery confirmation
  notes           String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           OrderItem[]
  payment         Payment?
  statusHistory   OrderStatusLog[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) // price at time of order
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

// ---------- PAYMENTS ----------

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  providerTxnId   String?       // txnRefNo from JazzCash/EasyPaisa
  providerRawResponse Json?     // full gateway response, for audits
  amount          Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ---------- MARKETING ----------

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   // "PERCENT" | "FLAT"
  discountValue Decimal  @db.Decimal(10, 2)
  minOrderValue Decimal  @db.Decimal(10, 2) @default(0)
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
}

// ---------- DELIVERY ZONES (single city, but Okara has distinct areas) ----------

model DeliveryZone {
  id          String  @id @default(cuid())
  areaName    String  @unique // e.g. "Model Town Okara", "Railway Colony"
  deliveryFee Decimal @db.Decimal(10, 2)
  etaMinutes  Int     @default(30)
  isActive    Boolean @default(true)
}
