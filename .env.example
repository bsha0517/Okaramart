# Database (use a hosted Postgres like Supabase, Neon, or Railway)
DATABASE_URL="postgresql://user:password@host:5432/okara_mart"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ---- JazzCash (Mobile Account / MA Payment) ----
# Get these from JazzCash merchant onboarding (https://www.jazzcash.com.pk/business/)
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_HASH_KEY=""
JAZZCASH_RETURN_URL="http://localhost:3000/api/payments/jazzcash/callback"
JAZZCASH_ENV="sandbox" # sandbox | production

# ---- EasyPaisa ----
# Get these from Telenor Microfinance Bank / EasyPaisa merchant onboarding
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""
EASYPAISA_RETURN_URL="http://localhost:3000/api/payments/easypaisa/callback"
EASYPAISA_ENV="sandbox"

# App
NEXT_PUBLIC_APP_NAME="Okara Mart"
NEXT_PUBLIC_CITY="Okara"

# ---- Google Maps (for checkout location pinpointing) ----
# Get a key from Google Cloud Console → APIs & Services → Credentials.
# Enable "Maps JavaScript API" and "Places API" for the project.
# Restrict the key to your domain (HTTP referrers) before going live.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ---- SMS (for OTP signup/login) ----
# "console" logs OTP codes to the server console instead of sending real SMS —
# fine for local dev. Switch to a real provider before launch (see lib/sms.ts).
# NOTE: customer login now defaults to phone+password (free) instead of OTP —
# this is only used if you switch back to OTP later.
SMS_PROVIDER="console"

# ---- Google login (customer-facing, free — no per-signup cost) ----
# Get these from Google Cloud Console → APIs & Services → Credentials →
# OAuth client ID (type: Web application).
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Facebook login (customer-facing, free) ----
# Get these from developers.facebook.com → your app → Settings → Basic.
# Valid OAuth redirect URI: https://yourdomain.com/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

